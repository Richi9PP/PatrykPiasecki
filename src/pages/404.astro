---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Not found" description="Page not found.">
  <section class="py-32">
    <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
      <p class="mb-4 font-display text-[clamp(64px,12vw,140px)] font-medium leading-none text-navy-950">
        404
      </p>
      <p class="mb-8 max-w-[42ch] text-lg text-muted">
        That page doesn't exist — or moved. Let's get you back on track.
      </p>
      <a
        href={`${base}/`}
        class="inline-flex items-center gap-2 rounded-[2px] bg-navy-950 px-[22px] py-[13px] text-sm font-medium text-surface transition-colors hover:bg-navy-700"
      >
        Back home
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
