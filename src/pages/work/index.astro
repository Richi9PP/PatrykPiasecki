---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHead from '../../components/SectionHead.astro';
import ProjectRow from '../../components/ProjectRow.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Work" description="Selected data science and full-stack projects by Patryk Piasecki.">
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
      <SectionHead
        kicker="Work"
        title="Selected projects."
        desc="Credit risk, quant finance, machine learning, and shipped products — presented as proof, not marketing."
      />
      <div class="flex flex-col">
        {
          projects.map((project, i) => (
            <ProjectRow
              index={i + 1}
              title={project.data.title}
              tags={project.data.tags}
              metric={project.data.metric}
              href={`${base}/work/${project.id}`}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
