---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { CONTACT } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allProjects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const projects = allProjects.slice(0, 3);
---

<BaseLayout>
  <Hero />

  <section id="work" class="py-16 sm:py-24">
    <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
      <SectionHead
        kicker="Selected work"
        title="Proof, not marketing."
        desc="From credit-risk scorecards to shipped products. Each one is a complete case study: the problem, what I built, the stack, and the measured outcome."
      />
      <div class="flex flex-col">
        {
          projects.map((project, i) => (
            <ProjectRow
              index={i + 1}
              title={project.data.title}
              tags={project.data.tags}
              metric={project.data.metric}
              href={`${base}/work/${project.id}`}
            />
          ))
        }
      </div>
      <div data-reveal class="mt-10">
        <a
          href={`${base}/work`}
          class="inline-flex items-center gap-2 border-b border-line-strong pb-0.5 text-sm font-medium text-ink transition-colors hover:border-ink"
        >
          See all {allProjects.length} projects
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section id="about" class="bg-navy-950 py-24 text-surface">
    <div class="mx-auto grid max-w-[1240px] grid-cols-1 items-start gap-6 px-5 sm:px-8 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:gap-20 lg:px-16">
      <div data-reveal>
        <p class="mb-3 text-[13px] font-medium tracking-[0.02em] text-navy-300">About</p>
        <h2 class="font-display text-[length:var(--text-h2)] font-medium leading-[1.08] tracking-[-0.01em] text-surface">
          Quant by training,<br />builder by habit.
        </h2>
      </div>
      <div data-reveal style="--reveal-delay: 120ms">
        <p class="mb-6 max-w-[56ch] text-base leading-[1.7] text-navy-100">
          I work on the DTC team at Warner Bros. Discovery while finishing a
          master's in Data Analysis at SGH Warsaw School of Economics. What I
          care about is the last mile: turning an analysis into something that
          runs, gets used, and actually changes a decision.
        </p>
        <a
          href={`${base}/about`}
          class="border-b border-navy-300 pb-0.5 text-sm font-medium text-surface transition-opacity hover:opacity-70"
        >
          Read the full story →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
