---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StackStrip from '../components/StackStrip.astro';
import SectionHead from '../components/SectionHead.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { CONTACT } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout>
  <Hero />

  <StackStrip />

  <section id="work" class="py-24">
    <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
      <SectionHead
        kicker="Selected work"
        title="Three projects, three proofs."
        desc="Each one is a complete case study — the problem, what I built, the stack, and the measured outcome."
      />
      <div class="flex flex-col">
        {
          projects.map((project, i) => (
            <ProjectRow
              index={i + 1}
              title={project.data.title}
              tags={project.data.tags}
              metric={project.data.metric}
              href={`${base}/work/${project.id}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section id="about" class="bg-navy-950 py-24 text-surface">
    <div class="mx-auto grid max-w-[1240px] grid-cols-1 items-start gap-8 px-5 sm:px-8 md:grid-cols-[0.9fr_1.1fr] md:gap-20 lg:px-16">
      <div>
        <p class="mb-3 text-[13px] font-medium tracking-[0.02em] text-navy-300">About</p>
        <h2 class="font-display text-[length:var(--text-h2)] font-medium leading-[1.08] tracking-[-0.01em] text-surface">
          Corporate discipline,<br />freelance range.
        </h2>
      </div>
      <div>
        <p class="mb-6 max-w-[56ch] text-base leading-[1.7] text-[oklch(0.85_0.02_258)]">
          I work on the DTC Team at Warner Bros. Discovery while finishing a
          master's in Data Analysis at SGH Warsaw School of Economics. Outside
          of that, I build and ship full-stack AI products — wiring LLMs, voice
          APIs, and databases into things people actually use.
        </p>
        <a
          href={`${base}/about`}
          class="border-b border-navy-300 pb-0.5 text-sm font-medium text-surface transition-opacity hover:opacity-70"
        >
          Read the full story →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
