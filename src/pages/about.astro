---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const facts = [
  { label: 'Currently', value: 'DTC Team @ Warner Bros. Discovery' },
  { label: 'Studying', value: "MSc Data Analysis, SGH — grad. 2027" },
  { label: 'Based in', value: 'Warsaw, Poland' },
  { label: 'Focus', value: 'ML models · full-stack AI products' },
];
---

<BaseLayout title="About" description="Patryk Piasecki — Data Scientist at WBD, MSc Data Analysis at SGH, full-stack AI builder.">
  <section class="py-24">
    <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-[1.15fr_0.85fr] md:gap-20">
        <div>
          <p class="mb-3 text-[13px] font-medium tracking-[0.02em] text-navy-500">About</p>
          <h1 class="mb-8 font-display text-[length:var(--text-h2)] font-medium leading-[1.08] tracking-[-0.01em] text-navy-950">
            Corporate discipline,<br />freelance range.
          </h1>

          <div class="max-w-[62ch] space-y-5 text-[17px] leading-[1.75] text-muted">
            <p>
              I'm a Data Scientist based in Warsaw. By day I work on the DTC Team
              at Warner Bros. Discovery; alongside that I'm finishing a master's
              in Data Analysis at SGH Warsaw School of Economics, graduating in
              2027.
            </p>
            <p>
              My work sits where machine learning meets shipping. I've trained
              classifiers with rigorous validation for academic projects, and
              I've built and deployed full-stack systems that run in production
              for real corporate clients — including a live photo pipeline used
              at events for PGE Narodowy and TVN.
            </p>
            <p>
              What I'm most interested in is full-stack AI product development:
              combining LLMs, voice APIs, and databases into working
              applications. I like the whole arc — from the model to the moment
              a person actually uses the thing.
            </p>
          </div>

          <div class="mt-10 flex flex-wrap gap-6 text-sm">
            <a
              href={`${base}/work`}
              class="inline-flex items-center gap-2 rounded-[2px] bg-navy-950 px-[22px] py-[13px] font-medium text-surface transition-colors hover:bg-navy-700"
            >
              See my work
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
            <a
              href={`${base}/contact`}
              class="self-center border-b border-line-strong pb-0.5 font-medium text-ink transition-colors hover:border-ink"
            >
              Get in touch
            </a>
          </div>
        </div>

        <div>
          <img
            src={`${base}/PatrykPiasecki_cutout.png`}
            alt="Patryk Piasecki"
            width="900"
            height="866"
            class="mb-8 w-full max-w-[340px]"
          />
          <dl class="border-t border-line">
            {
              facts.map((fact) => (
                <div class="border-b border-line py-4">
                  <dt class="mb-1.5 text-xs uppercase tracking-[0.06em] text-faint">
                    {fact.label}
                  </dt>
                  <dd class="font-display text-[17px] text-navy-950">{fact.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
