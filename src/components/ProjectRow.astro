---
interface Props {
  index: number;
  title: string;
  tags: string[];
  metric: string;
  href: string;
}
const { index, title, tags, metric, href } = Astro.props;
const num = String(index).padStart(2, '0');
const delay = Math.min(index - 1, 5) * 70;
---

<a
  href={href}
  data-reveal
  style={`--reveal-delay: ${delay}ms`}
  class="group grid grid-cols-1 items-center gap-5 border-t border-line py-8 transition-colors last:border-b hover:bg-surface-alt md:grid-cols-[64px_minmax(0,1fr)_minmax(0,1.1fr)] md:gap-8 md:py-12"
>
  <span class="font-display text-[15px] italic text-faint">{num}</span>

  <div>
    <h3 class="mb-3 font-display text-[length:var(--text-h3)] font-medium tracking-[-0.01em] text-navy-950">
      {title}
    </h3>
    <div class="flex flex-wrap gap-3">
      {
        tags.map((tag) => (
          <span class="rounded-[2px] border border-line-strong px-2.5 py-1 text-[11px] uppercase tracking-[0.04em] text-navy-500">
            {tag}
          </span>
        ))
      }
    </div>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
    <p class="max-w-[34ch] text-sm leading-relaxed text-muted">{metric}</p>
    <span
      class="flex h-9 w-9 shrink-0 items-center justify-center self-end rounded-full border border-line-strong transition-all group-hover:border-navy-950 group-hover:bg-navy-950 sm:self-auto"
    >
      <svg
        class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:stroke-surface"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M7 17L17 7M17 7H8M17 7V16"></path>
      </svg>
    </span>
  </div>
</a>
