---
import { SITE } from '../consts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative grid min-h-[calc(100vh-90px)] grid-cols-[28px_1fr] overflow-hidden">
  <!-- vertical rail label -->
  <div class="hidden items-end justify-center py-12 md:flex">
    <span
      class="whitespace-nowrap text-xs uppercase tracking-[0.14em] text-faint [writing-mode:vertical-rl] rotate-180"
    >
      {SITE.role} — {SITE.location.split(',')[0]}
    </span>
  </div>

  <div>
    <div class="relative mx-auto grid max-w-[1240px] grid-cols-1 items-center gap-2 px-5 py-12 sm:px-8 md:grid-cols-[1.1fr_0.9fr] lg:px-16">
      <!-- confined blueprint grid behind the portrait -->
      <div
        class="hero-grid-backdrop pointer-events-none absolute inset-y-0 right-[-6%] left-auto z-0 hidden w-[58%] md:block"
        aria-hidden="true"
      >
      </div>

      <!-- copy -->
      <div class="relative z-20">
        <h1 class="mb-6 font-display text-[length:var(--text-hero)] font-medium leading-[0.98] tracking-[-0.02em] text-navy-950">
          Data, made<br /><em class="not-italic italic text-navy-500">decidable.</em>
        </h1>
        <p class="mb-8 max-w-[46ch] text-base leading-relaxed text-muted sm:text-lg">
          I build machine learning models and the full-stack systems that put
          them to work — from a 95.6% accuracy classifier to a live photo
          pipeline running at corporate events for PGE Narodowy and TVN.
        </p>
        <div class="flex items-center gap-8">
          <a
            href={`${base}/work`}
            class="inline-flex items-center gap-2 rounded-[2px] bg-navy-950 px-[22px] py-[13px] text-sm font-medium text-surface transition-colors hover:bg-navy-700"
          >
            View selected work
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M13 6l6 6-6 6"></path>
            </svg>
          </a>
          <a
            href={`${base}/about`}
            class="border-b border-line-strong pb-0.5 text-sm font-medium text-ink transition-colors hover:border-ink"
          >
            About me
          </a>
        </div>
      </div>

      <!-- portrait -->
      <div class="relative z-10 -mt-12 -ml-12 justify-self-end self-end w-full max-w-[440px]">
        <p
          class="greeting-halo absolute top-[55%] left-[-22%] z-40 m-0 whitespace-nowrap font-display text-[clamp(23px,2.5vw,31px)] font-medium italic leading-tight tracking-[-0.01em] text-navy-950"
        >
          Hi, I'm <strong class="font-semibold not-italic text-navy-500">Patryk</strong>
        </p>

        <div
          class="hero-dotgrid absolute right-[-6%] bottom-[12%] z-20 h-[66px] w-[66px] opacity-50"
          aria-hidden="true"
        >
        </div>

        <img
          class="portrait-shadow relative z-10 block h-auto w-full"
          src={`${base}/PatrykPiasecki_cutout.png`}
          alt="Patryk Piasecki"
          width="900"
          height="866"
          fetchpriority="high"
        />

        <div
          class="absolute bottom-[10%] left-[-10%] z-20 flex items-center gap-2 rounded-full border border-line-strong bg-surface px-4 py-2.5 pl-3 text-xs font-medium text-navy-900 shadow-[0_12px_28px_oklch(0.2_0.045_258/0.14)]"
        >
          <span class="h-[7px] w-[7px] shrink-0 rounded-full bg-navy-500"></span>
          WBD — DTC Team
        </div>
      </div>
    </div>

    <div class="mx-auto flex max-w-[1240px] items-center justify-between border-t border-line px-5 py-6 text-xs tracking-[0.04em] text-faint sm:px-8 lg:px-16">
      <span>{SITE.location} — {new Date().getFullYear()}</span>
      <a href="#work" class="inline-flex items-center gap-2 transition-colors hover:text-ink">
        Scroll
        <svg class="scroll-cue-arrow h-[11px] w-[11px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
