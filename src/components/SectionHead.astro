---
interface Props {
  kicker: string;
  title: string;
  desc?: string;
}
const { kicker, title, desc } = Astro.props;
---

<div data-reveal class="mb-10 grid grid-cols-1 items-end gap-6 md:mb-16 md:grid-cols-2 md:gap-8">
  <div>
    <p class="mb-3 text-[13px] font-medium tracking-[0.02em] text-navy-500">{kicker}</p>
    <h2 class="font-display text-[length:var(--text-h2)] font-medium leading-[1.08] tracking-[-0.01em] text-navy-950">
      <slot name="title">{title}</slot>
    </h2>
  </div>
  {
    desc && (
      <p class="max-w-[42ch] text-[15px] leading-relaxed text-muted md:justify-self-end">
        {desc}
      </p>
    )
  }
</div>
