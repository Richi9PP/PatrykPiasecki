---
import { CONTACT } from '../consts';
const year = new Date().getFullYear();
---

<footer id="contact-footer" class="mt-24 border-t border-line py-12">
  <div class="mx-auto max-w-[1240px] px-5 sm:px-8 lg:px-16">
    <div class="flex flex-wrap items-center justify-between gap-4 text-sm text-faint">
      <span>© {year} Patryk Piasecki</span>
      <div class="flex gap-8">
        <a href={CONTACT.linkedin} class="transition-colors hover:text-ink" target="_blank" rel="noopener">LinkedIn</a>
        <a href={CONTACT.github} class="transition-colors hover:text-ink" target="_blank" rel="noopener">GitHub</a>
        <a href={`mailto:${CONTACT.email}`} class="transition-colors hover:text-ink">Email</a>
      </div>
    </div>
  </div>
</footer>
