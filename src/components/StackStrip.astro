---
import { STACK } from '../consts';

// The ticker needs two identical halves: the track slides by exactly one half,
// so the second copy lands where the first started and the loop never shows a seam.
const itemClass = 'shrink-0 whitespace-nowrap';
const listClass =
  'flex shrink-0 items-center gap-x-10 pr-10 font-display text-[16px] italic text-navy-700';
---

<!--
  No visible label, so the strip runs edge to edge. The name of the thing lives on
  the list itself instead — without it a screen reader gets twenty bare nouns and
  no clue what they are.
-->
<div class="border-y border-line py-4 sm:py-5">
  <div class="marquee marquee-mask">
    <div class="marquee-track flex w-max">
      <ul class={listClass} aria-label="Working with">
        {STACK.map((item) => <li class={itemClass}>{item}</li>)}
      </ul>
      <ul class={listClass} aria-hidden="true">
        {STACK.map((item) => <li class={itemClass}>{item}</li>)}
      </ul>
    </div>
  </div>
</div>
