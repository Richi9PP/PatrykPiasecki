---
import { STACK } from '../consts';
---

<div class="border-y border-line py-6">
  <div class="mx-auto flex max-w-[1240px] flex-wrap items-center gap-x-16 gap-y-4 px-5 sm:px-8 lg:px-16">
    <span class="shrink-0 text-xs uppercase tracking-[0.12em] text-faint">Working with</span>
    <div class="flex flex-wrap gap-x-12 gap-y-2 font-display text-[17px] italic text-navy-700">
      {STACK.map((item) => <span>{item}</span>)}
    </div>
  </div>
</div>
